/* pages/user/privacy/privacy.wxss */
.container {
  min-height: 100vh;
  background: #ffffff;
  padding-bottom: 40rpx;
}

.header {
  padding: 60rpx 40rpx 40rpx;
  background: linear-gradient(135deg, #4A90E2, #00D2D3);
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 12rpx;
}

.date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
}

.content {
  padding: 40rpx;
}

.section {
  margin-bottom: 48rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.text {
  font-size: 28rpx;
  color: #666;
  line-height: 48rpx;
  display: block;
  margin-bottom: 12rpx;
}