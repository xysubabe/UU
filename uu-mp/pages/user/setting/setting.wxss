/* pages/user/setting/setting.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 100rpx;
}

.setting-list {
  padding: 20rpx;
}

.section-title {
  font-size: 24rpx;
  color: #999;
  padding: 20rpx 10rpx;
}

.setting-item {
  background: #ffffff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.setting-item:first-child {
  border-radius: 16rpx 16rpx 0 0;
}

.setting-item:last-child {
  border-bottom: none;
  border-radius: 0 0 16rpx 16rpx;
}

.setting-label {
  font-size: 32rpx;
  color: #333;
}

.setting-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.setting-value {
  font-size: 28rpx;
  color: #999;
}

.setting-arrow {
  font-size: 40rpx;
  color: #ccc;
}

.switch-container {
  padding: 8rpx;
}

.switch {
  width: 80rpx;
  height: 44rpx;
  background: #ddd;
  border-radius: 22rpx;
  position: relative;
  transition: all 0.3s;
}

.switch.on {
  background: #4A90E2;
}

.switch-dot {
  width: 36rpx;
  height: 36rpx;
  background: #ffffff;
  border-radius: 50%;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  transition: all 0.3s;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.2);
}

.switch.on .switch-dot {
  left: 40rpx;
}

.logout-section {
  padding: 40rpx 20rpx;
}

.btn-logout {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #ffffff;
  color: #FF6B6B;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
}