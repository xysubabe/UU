/* pages/user/service/service.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  padding: 60rpx 40rpx 40rpx;
  background: linear-gradient(135deg, #4A90E2, #00D2D3);
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
}

.content {
  padding: 20rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.icon {
  font-size: 40rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.card-desc {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
  margin-left: 56rpx;
}

.card-time {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-left: 56rpx;
}

.section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
}

.faq-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.faq-icon {
  font-size: 32rpx;
}

.faq-title {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.faq-arrow {
  font-size: 40rpx;
  color: #ccc;
}

.feedback-section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.feedback-input {
  width: 100%;
  min-height: 200rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  margin-bottom: 12rpx;
}

.feedback-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.btn-submit {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #4A90E2;
  color: #ffffff;
  border-radius: 44rpx;
  font-size: 32rpx;
  border: none;
}

.btn-submit[disabled] {
  opacity: 0.6;
}