<!-- pages/user/service/service.wxml -->
<view class="container">
  <view class="header">
    <text class="title">联系客服</text>
    <text class="subtitle">我们随时为您提供帮助</text>
  </view>

  <view class="content">
    <!-- 客服热线 -->
    <view class="card" bindtap="callPhone">
      <view class="card-header">
        <text class="icon">📞</text>
        <text class="card-title">客服热线</text>
      </view>
      <text class="card-desc">400-XXX-XXXX</text>
      <text class="card-time">工作日 9:00-21:00</text>
    </view>

    <!-- 在线客服 -->
    <view class="card" bindtap="contactOnline">
      <view class="card-header">
        <text class="icon">💬</text>
        <text class="card-title">在线客服</text>
      </view>
      <text class="card-desc">24小时在线</text>
      <text class="card-time">平均响应时间 5 分钟</text>
    </view>

    <!-- 常见问题 -->
    <view class="section">
      <text class="section-title">常见问题</text>

      <view class="faq-item" bindtap="showFaq" data-type="cancel">
        <view class="faq-header">
          <text class="faq-icon">❓</text>
          <text class="faq-title">如何取消订单？</text>
          <text class="faq-arrow">›</text>
        </view>
      </view>

      <view class="faq-item" bindtap="showFaq" data-type="payment">
        <view class="faq-header">
          <text class="faq-icon">❓</text>
          <text class="faq-title">如何支付费用？</text>
          <text class="faq-arrow">›</text>
        </view>
      </view>

      <view class="faq-item" bindtap="showFaq" data-type="address">
        <view class="faq-header">
          <text class="faq-icon">❓</text>
          <text class="faq-title">如何添加收货地址？</text>
          <text class="faq-arrow">›</text>
        </view>
      </view>

      <view class="faq-item" bindtap="showFaq" data-type="refund">
        <view class="faq-header">
          <text class="faq-icon">❓</text>
          <text class="faq-title">如何申请退款？</text>
          <text class="faq-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 意见反馈 -->
    <view class="feedback-section">
      <text class="section-title">意见反馈</text>
      <textarea class="feedback-input" placeholder="请描述您遇到的问题或建议（选填）" value="{{feedback}}" bindinput="onFeedbackInput" maxlength="500"></textarea>
      <view class="feedback-count">{{feedback.length}}/500</view>
      <button class="btn-submit" bindtap="submitFeedback" disabled="{{submitting}}">
        {{ submitting ? '提交中...' : '提交反馈' }}
      </button>
    </view>
  </view>
</view>