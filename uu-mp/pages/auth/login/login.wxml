<!-- pages/auth/login/login.wxml -->
<view class="container">
  <!-- Logo区域 -->
  <view class="logo-section">
    <view class="logo-icon">UU</view>
    <text class="app-name">UU 跑腿</text>
    <text class="app-slogan">专业跑腿服务，生活更便捷</text>
  </view>

  <!-- 登录区域 -->
  <view class="login-section">
    <view class="login-tips">
      <text class="tip-icon">🔒</text>
      <text class="tip-text">为了保障您的账户安全，请登录后使用</text>
    </view>

    <button class="btn-wechat" bindtap="wechatLogin" disabled="{{logging}}">
      <text class="btn-icon" wx:if="{{!logging}}">💚</text>
      <text class="btn-text">{{ logging ? '登录中...' : '微信一键登录' }}</text>
    </button>

    <view class="agreement-section">
      <view class="checkbox-container" bindtap="toggleAgreement">
        <view class="checkbox {{agreed ? 'checked' : ''}}">
          <text class="checkbox-icon" wx:if="{{agreed}}">✓</text>
        </view>
      </view>
      <text class="agreement-text">
        阅读并同意
        <text class="agreement-link" bindtap="showUserAgreement">《用户协议》</text>
        和
        <text class="agreement-link" bindtap="showPrivacyPolicy">《隐私政策》</text>
      </text>
    </view>
  </view>

  <!-- 底部信息 -->
  <view class="footer-section">
    <text class="footer-text">登录即表示同意用户协议和隐私政策</text>
    <text class="copyright">© 2026 UU 跑腿 版权所有</text>
  </view>
</view>