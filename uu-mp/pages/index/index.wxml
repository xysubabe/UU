<!-- pages/index/index.wxml -->
<view class="container">
  <!-- 顶部搜索栏 -->
  <view class="search-bar">
    <input class="search-input" placeholder="搜索跑腿服务" />
  </view>

  <!-- 服务类型 -->
  <view class="section">
    <view class="section-title">选择服务</view>
    <view class="service-list">
      <view class="service-type" bindtap="navigateToCreateOrder" data-type="1">
        <view class="service-icon">🛒</view>
        <view class="service-text">
          <view class="service-name">帮买</view>
          <view class="service-desc">帮你代买商品</view>
        </view>
      </view>
      <view class="service-type" bindtap="navigateToCreateOrder" data-type="2">
        <view class="service-icon">🚚</view>
        <view class="service-text">
          <view class="service-name">帮送</view>
          <view class="service-desc">帮你同城配送</view>
        </view>
      </view>
      <view class="service-type" bindtap="navigateToCreateOrder" data-type="3">
        <view class="service-icon">🚶</view>
        <view class="service-text">
          <view class="service-name">帮排队</view>
          <view class="service-desc">帮你代排队</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 进行中订单 -->
  <view class="section">
    <view class="section-title">
      <text>进行中订单</text>
      <text class="more" bindtap="navigateToOrderList">查看全部</text>
    </view>
    <view class="ongoing-list" wx:if="{{ongoingOrders.length > 0}}">
      <view class="order-item" wx:for="{{ongoingOrders}}" wx:key="id" bindtap="navigateToOrderDetail" data-id="{{item.id}}">
        <view class="order-header">
          <text class="service-type-text">{{item.serviceTypeDesc}}</text>
          <text class="order-status" style="color: {{item.statusColor}}">{{item.statusDesc}}</text>
        </view>
        <view class="order-content">
          <text class="order-desc">{{item.description || '无描述'}}</text>
          <view class="order-info">
            <text class="order-amount">¥{{item.amount}}</text>
            <text class="order-time">{{item.createTime}}</text>
          </view>
        </view>
      </view>
    </view>
    <view class="empty-state" wx:else>
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无进行中订单</text>
    </view>
  </view>
</view>