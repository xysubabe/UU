/* pages/index/index.wxss */
.container {
  min-height: 100vh;
}

.search-bar {
  padding: 20rpx;
  background: #4A90E2;
}

.search-input {
  width: 100%;
  height: 70rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 35rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
}

.section {
  padding: 20rpx;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.more {
  font-size: 24rpx;
  color: #4A90E2;
}

.service-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.service-type {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.service-icon {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #4A90E2, #00D2D3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 24rpx;
}

.service-text {
  flex: 1;
}

.service-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.service-desc {
  font-size: 24rpx;
  color: #999;
}

.ongoing-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.order-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.service-type-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.order-status {
  font-size: 24rpx;
  font-weight: bold;
}

.order-content {
  display: flex;
  flex-direction: column;
}

.order-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-amount {
  font-size: 32rpx;
  font-weight: bold;
  color: #FF6B6B;
}

.order-time {
  font-size: 24rpx;
  color: #999;
}

.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}