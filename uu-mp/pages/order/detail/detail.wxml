<!-- pages/order/detail/detail.wxml -->
<view class="container">
  <!-- 订单状态 -->
  <view class="status-header" style="background: linear-gradient(135deg, {{statusColor}}, {{statusColorLight}})">
    <text class="status-icon">{{statusIcon}}</text>
    <text class="status-text">{{order.statusDesc}}</text>
    <text class="status-desc">{{order.orderNo}}</text>
  </view>

  <!-- 服务信息 -->
  <view class="section">
    <view class="section-title">服务信息</view>
    <view class="info-list">
      <view class="info-item">
        <text class="info-label">服务类型</text>
        <text class="info-value">{{order.serviceTypeDesc}}</text>
      </view>
      <view class="info-item" wx:if="{{order.description}}">
        <text class="info-label">服务描述</text>
        <text class="info-value">{{order.description}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">下单时间</text>
        <text class="info-value">{{order.createTime}}</text>
      </view>
    </view>
  </view>

  <!-- 地址信息 -->
  <view class="section" wx:if="{{order.startAddress || order.endAddress || order.queueAddress}}">
    <view class="section-title">地址信息</view>
    <view class="address-list">
      <!-- 帮送：取件地址 -->
      <view class="address-item" wx:if="{{order.startAddress}}">
        <text class="address-label">取件地址</text>
        <view class="address-content">
          <text class="address-text">{{order.startAddress.fullAddress}}</text>
          <text class="address-contact">{{order.startAddress.contactName}} {{order.startAddress.contactPhone}}</text>
        </view>
      </view>
      <!-- 帮买/帮送：收货/送达地址 -->
      <view class="address-item" wx:if="{{order.endAddress}}">
        <text class="address-label">{{order.serviceType === 1 ? '收货地址' : '送达地址'}}</text>
        <view class="address-content">
          <text class="address-text">{{order.endAddress.fullAddress}}</text>
          <text class="address-contact">{{order.endAddress.contactName}} {{order.endAddress.contactPhone}}</text>
        </view>
      </view>
      <!-- 帮排队：排队地址 -->
      <view class="address-item" wx:if="{{order.queueAddress}}">
        <text class="address-label">排队地址</text>
        <view class="address-content">
          <text class="address-text">{{order.queueAddress.fullAddress}}</text>
          <text class="address-contact">{{order.queueAddress.contactName}} {{order.queueAddress.contactPhone}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 费用信息 -->
  <view class="section">
    <view class="section-title">费用信息</view>
    <view class="fee-list">
      <view class="fee-item">
        <text class="fee-label">跑腿费用</text>
        <text class="fee-value">¥{{order.amount}}</text>
      </view>
      <view class="fee-total">
        <text class="fee-label">合计</text>
        <text class="fee-value fee-total-amount">¥{{order.amount}}</text>
      </view>
    </view>
  </view>

  <!-- 订单日志 -->
  <view class="section" wx:if="{{orderLogs.length > 0}}">
    <view class="section-title">订单动态</view>
    <view class="log-list">
      <view class="log-item" wx:for="{{orderLogs}}" wx:key="id">
        <view class="log-time">{{item.createTime}}</view>
        <view class="log-content">
          <text class="log-title">{{item.title}}</text>
          <text class="log-desc" wx:if="{{item.description}}">{{item.description}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="footer-actions" wx:if="{{order.status < 300 && order.status !== 999}}">
    <button class="btn btn-cancel" bindtap="cancelOrder">取消订单</button>
    <button class="btn btn-contact" wx:if="{{order.status >= 200}}">联系骑手</button>
  </view>
</view>