<!-- pages/order/create/create.wxml -->
<view class="container">
  <!-- 服务类型标题 -->
  <view class="header">
    <text class="title">{{ serviceTitle }}</text>
  </view>

  <!-- 表单 -->
  <view class="form">
    <!-- 帮买表单 -->
    <view class="form-group" wx:if="{{type === '1'}}">
      <view class="form-item">
        <text class="label">购买地址</text>
        <view class="address-select" bindtap="selectEndAddress">
          <text wx:if="{{endAddress}}" class="address-text">
            {{endAddress.fullAddress}}
          </text>
          <text wx:else class="address-placeholder">选择购买地址</text>
          <text class="arrow">›</text>
        </view>
      </view>
      <view class="form-item">
        <text class="label">购买清单</text>
        <textarea class="textarea" placeholder="请输入需要购买的商品清单（选填）" value="{{description}}" bindinput="onDescriptionInput" maxlength="200"></textarea>
      </view>
    </view>

    <!-- 帮送表单 -->
    <view class="form-group" wx:if="{{type === '2'}}">
      <view class="form-item">
        <text class="label">取件地址</text>
        <view class="address-select" bindtap="selectStartAddress">
          <text wx:if="{{startAddress}}" class="address-text">
            {{startAddress.fullAddress}}
          </text>
          <text wx:else class="address-placeholder">选择取件地址</text>
          <text class="arrow">›</text>
        </view>
      </view>
      <view class="form-item">
        <text class="label">送达地址</text>
        <view class="address-select" bindtap="selectEndAddress">
          <text wx:if="{{endAddress}}" class="address-text">
            {{endAddress.fullAddress}}
          </text>
          <text wx:else class="address-placeholder">选择送达地址</text>
          <text class="arrow">›</text>
        </view>
      </view>
      <view class="form-item">
        <text class="label">物品描述</text>
        <textarea class="textarea" placeholder="请输入物品描述（选填）" value="{{description}}" bindinput="onDescriptionInput" maxlength="200"></textarea>
      </view>
    </view>

    <!-- 帮排列表单 -->
    <view class="form-group" wx:if="{{type === '3'}}">
      <view class="form-item">
        <text class="label">排队地址</text>
        <view class="address-select" bindtap="selectQueueAddress">
          <text wx:if="{{queueAddress}}" class="address-text">
            {{queueAddress.fullAddress}}
          </text>
          <text wx:else class="address-placeholder">选择排队地址</text>
          <text class="arrow">›</text>
        </view>
      </view>
      <view class="form-item">
        <text class="label">排队事项</text>
        <textarea class="textarea" placeholder="请输入需要排队办理的事项（选填）" value="{{description}}" bindinput="onDescriptionInput" maxlength="200"></textarea>
      </view>
    </view>

    <!-- 跑腿费用 -->
    <view class="form-group">
      <view class="form-item">
        <text class="label">跑腿费用（元）</text>
        <input class="input" type="number" placeholder="请输入跑腿费用" value="{{amount}}" bindinput="onAmountInput" />
        <text class="unit">元</text>
      </view>
    </view>

    <!-- 提交按钮 -->
    <view class="btn-group">
      <button class="btn btn-primary" bindtap="submitOrder" disabled="{{!canSubmit}}">
        {{ submitting ? '提交中...' : '确认下单' }}
      </button>
    </view>
  </view>
</view>