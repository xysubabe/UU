/* pages/order/create/create.wxss */
.header {
  padding: 30rpx 20rpx;
  background: #4A90E2;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}

.form {
  padding: 20rpx;
}

.form-group {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
}

.unit {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
  color: #999;
}

.textarea {
  width: 100%;
  min-height: 200rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.address-select {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 24rpx;
  height: 88rpx;
}

.address-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.address-placeholder {
  flex: 1;
  font-size: 28rpx;
  color: #999;
}

.arrow {
  font-size: 48rpx;
  color: #999;
}

.btn-group {
  margin-top: 40rpx;
}

.btn {
  margin-bottom: 20rpx;
}

.btn[disabled] {
  opacity: 0.6;
}