/* pages/address/list/list.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

.address-list {
  padding: 20rpx;
}

.address-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.address-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.contact-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.contact-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.contact-phone {
  font-size: 28rpx;
  color: #666;
}

.default-badge {
  background: #4A90E2;
  color: #ffffff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.address-actions {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  font-size: 28rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.edit {
  color: #4A90E2;
  background: rgba(74, 144, 226, 0.1);
}

.delete {
  color: #FF6B6B;
  background: rgba(255, 107, 107, 0.1);
}

.address-content {
  display: flex;
  flex-direction: column;
}

.full-address {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.detailed-address {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.empty-state {
  text-align: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 20rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.loading {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 28rpx;
}

.footer-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 20rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.btn-primary {
  background: #4A90E2;
  color: #ffffff;
}

.btn-icon {
  font-size: 40rpx;
  font-weight: bold;
}