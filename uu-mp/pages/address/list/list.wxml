<!-- pages/address/list/list.wxml -->
<view class="container">
  <!-- 地址列表 -->
  <view class="address-list">
    <view class="address-item" wx:for="{{addressList}}" wx:key="id" bindtap="selectAddress" data-address="{{item}}">
      <view class="address-header">
        <view class="contact-info">
          <text class="contact-name">{{item.contactName}}</text>
          <text class="contact-phone">{{item.contactPhone}}</text>
          <text class="default-badge" wx:if="{{item.isDefault}}">默认</text>
        </view>
        <view class="address-actions">
          <text class="action-btn edit" bindtap="editAddress" data-id="{{item.id}}" catchtap="true">编辑</text>
          <text class="action-btn delete" bindtap="deleteAddress" data-id="{{item.id}}" catchtap="true">删除</text>
        </view>
      </view>
      <view class="address-content">
        <text class="full-address">{{item.fullAddress}}</text>
        <text class="detailed-address" wx:if="{{item.detailedAddress}}">{{item.detailedAddress}}</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{addressList.length === 0 && !loading}}">
    <text class="empty-icon">📍</text>
    <text class="empty-text">暂无地址</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 底部添加按钮 -->
  <view class="footer-actions" wx:if="{{addressList.length < 3}}">
    <button class="btn btn-primary" bindtap="addAddress">
      <text class="btn-icon">+</text>
      <text>添加新地址</text>
    </button>
  </view>
</view>